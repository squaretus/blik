#!/bin/bash
# Остановить старый daemon и agent если обновление

# Определить GUI-пользователя (при обновлении через daemon $USER=root)
CONSOLE_USER=$(/usr/bin/stat -f '%Su' /dev/console 2>/dev/null || echo "")
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    CURRENT_UID=$(id -u "$CONSOLE_USER")
else
    CURRENT_UID=$(id -u "$USER")
fi

# Убить MenuBar app (надёжнее чем только bootout)
killall BlikMenuBar 2>/dev/null || true

# Выгрузить LaunchAgent и LaunchDaemon
launchctl bootout gui/"$CURRENT_UID"/com.blik.app 2>/dev/null || true
launchctl bootout system/com.blik.helper 2>/dev/null || true
exit 0
